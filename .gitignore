# Python
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.env
.venv
venv/

# Conda environments (large, reproducible via bootstrap)
envs/

# Legacy genome dir — superseded by data/core_test_data_{build}/genome/
data/genomes/

# Large binary files in core test data (tracked via manifest + provenance, not git LFS)
data/core_test_data_*/genome/*.fa
data/core_test_data_*/genome/*.fa.*
data/core_test_data_*/short_read/**/*.fastq.gz
data/core_test_data_*/long_read/**/*.fastq.gz
data/core_test_data_*/long_read/**/*.pod5
data/core_test_data_*/long_read/**/*.fast5
data/core_test_data_*/pipeline_outputs/**/*.bam
data/core_test_data_*/pipeline_outputs/**/*.bai
data/core_test_data_*/pipeline_outputs/**/*.sam
data/core_test_data_*/pipeline_outputs/**/*.vcf

# Raw source reads cache — eliminated; reads are now stream-subsetted directly
data/sources/

# Old test_data dir — superseded by data/core_test_data_{build}/
data/test_data/

# Generated data artifacts (manifest, provenance, sample metadata)
# Regenerated by the agent; do not track in git
data/core_test_data_*/manifest.yaml
data/core_test_data_*/**/*_provenance.yaml
data/core_test_data_*/**/*_sample_meta.yaml

# Generated Docker artifacts (large)
docker_images/*/

# Generated pipeline configs are artifacts — commit selectively
# config/pipelines/  ← uncomment to exclude generated pipeline specs

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
